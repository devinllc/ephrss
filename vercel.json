{
    "version": 2,
    "builds": [
      {
        "src": "app.js",
        "use": "@vercel/node"
      }
    ],
    "routes": [
      {
        "src": "/(.*)",
        "dest": "/app.js"
      }
    ],
    "crons": [
      {
        "path": "/api/cron/performance",
        "schedule": "55 23 * * *"
      }
    ]
  }
  